# Server port (default 8000). Use 80 for EC2 if running with sudo or behind a reverse proxy.
# PORT=8000

# Upstream HTTP base URL (default: https://jsonplaceholder.typicode.com)
# For docker-compose testing, use: http://target-service:8080
# UPSTREAM_BASE_URL=https://jsonplaceholder.typicode.com

# Simulated network latency in milliseconds (default: 100)
# PROXY_LATENCY_MS=100

# Upstream request timeout in seconds (default: 30)
UPSTREAM_TIMEOUT_SECONDS=30

# Flakiness simulator: percentage of requests to fail with 503/504 (0 = disabled)
FLAKINESS_PERCENTAGE=5

# WebSocket upstream base URL (default: wss://echo.websocket.org for testing)
# WS_UPSTREAM_BASE_URL=wss://echo.websocket.org
